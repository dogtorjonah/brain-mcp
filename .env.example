# brain-mcp configuration
# Copy this file to .env and uncomment/edit values as needed.

# ── Core paths ──────────────────────────────────────────────────────────
# Base directory for all brain data (defaults to ~/.brain)
# BRAIN_HOME=/path/to/.brain

# Unix socket for daemon IPC (defaults to $BRAIN_HOME/sock)
# BRAIN_SOCKET_PATH=/path/to/brain.sock

# SQLite database path (defaults to $BRAIN_HOME/brain.sqlite)
# BRAIN_HOME_DB=/path/to/brain.sqlite

# ── Daemon ──────────────────────────────────────────────────────────────
# Health-check HTTP port (default: 4815)
# BRAIN_HEALTH_PORT=4815

# Override the daemon binary command (default: auto-detected)
# BRAIN_DAEMON_COMMAND=node

# Extra arguments passed to the daemon process
# BRAIN_DAEMON_ARGS=

# ── Claude Code wrapper (set automatically by brain-claude) ─────────────
# These are normally injected by the wrapper script, not set by hand.

# Project directory for the current session
# BRAIN_WRAPPER_PROJECT_DIR=/path/to/project

# PID of the wrapper process
# BRAIN_WRAPPER_PID=

# Path to the claude binary
# BRAIN_CLAUDE_BIN=claude

# ── Claude Code session context (set automatically) ─────────────────────
# Active identity name
# CLAUDE_IDENTITY=

# Active session ID
# CLAUDE_SESSION_ID=

# Claude project directory
# CLAUDE_PROJECT_DIR=

# Engine identifier (used for atlas commit attribution)
# CLAUDE_ENGINE=

# ── Atlas auto-refresh ─────────────────────────────────────────────────
# Enable/disable Atlas auto-refresh on file changes (default: auto)
# BRAIN_ATLAS_AUTO_REFRESH=auto

# Debounce interval in ms for auto-refresh batches (default: 1500)
# BRAIN_ATLAS_AUTO_REFRESH_DEBOUNCE_MS=1500

# Minimum cooldown between refresh cycles in ms (default: 5000)
# BRAIN_ATLAS_AUTO_REFRESH_COOLDOWN_MS=5000

# Max files per batch refresh (default: 50)
# BRAIN_ATLAS_AUTO_REFRESH_MAX_BATCH=50

# Enable file watcher in standalone Atlas mode (default: disabled)
# BRAIN_ATLAS_STANDALONE_WATCH=0

# ── Embeddings ─────────────────────────────────────────────────────────
# Use a worker thread for embedding generation (default: disabled)
# BRAIN_EMBED_WORKER=1

# ── Self-spawn (Python bridge) ─────────────────────────────────────────
# Python binary for self-spawn (default: python3)
# BRAIN_SELFSPAWN_PYTHON=python3

# ── Tool overrides ─────────────────────────────────────────────────────
# Explicit path to ripgrep binary (default: auto-detected)
# RG_BIN=/usr/bin/rg
# RIPGREP_BIN=/usr/bin/rg

# ── Legacy aliases (REBIRTH_* prefix) ──────────────────────────────────
# These are older names still accepted as fallbacks.
# REBIRTH_WRAPPER_PID=
# REBIRTH_WRAPPER_PROJECT_DIR=
# REBIRTH_CLAUDE_BIN=claude
# REBIRTH_SELFSPAWN_PYTHON=python3
