{
  "name": "@voxxo/brain-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone MCP brain for Claude Code: identity, transcripts, Atlas code memory, synapse edges, and unified search.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dogtorjonah/brain-mcp.git"
  },
  "homepage": "https://github.com/dogtorjonah/brain-mcp",
  "bugs": {
    "url": "https://github.com/dogtorjonah/brain-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "dist/bin/brain-mcp.js",
  "bin": {
    "brain-mcp": "./dist/bin/brain-mcp.js",
    "brain-daemon": "./dist/bin/brain-daemon.js",
    "brain-claude": "./bin/brain-claude",
    "brain": "./dist/cli/brain.js"
  },
  "files": [
    "dist",
    "bin",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/bin/brain-mcp.js dist/bin/brain-daemon.js dist/cli/brain.js dist/cli/migrate.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/bin/brain-mcp.ts",
    "dev:daemon": "tsx watch src/bin/brain-daemon.ts",
    "start": "node dist/bin/brain-mcp.js",
    "start:daemon": "node dist/bin/brain-daemon.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "better-sqlite3": "^12.9.0",
    "sqlite-vec": "^0.1.9",
    "tree-sitter": "0.21.1",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-python": "0.23.2",
    "tree-sitter-rust": "0.21.0",
    "tree-sitter-typescript": "0.23.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "memory",
    "atlas",
    "rebirth",
    "sqlite"
  ]
}
